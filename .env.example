# ── OBS WebSocket ─────────────────────────────────────────────────
OBS_WEBSOCKET_URL=ws://localhost:4455
OBS_WEBSOCKET_PASSWORD=changeme

# ── Audio backend ─────────────────────────────────────────────────
#   auto        → Voicemeeter if installed & reachable, else native, else none
#   voicemeeter → Force Voicemeeter (full feature set, requires the app)
#   native      → native-sound-mixer (per-app volume, no extra software)
#   none        → Disable audio (OBS scene switching still works)
AUDIO_BACKEND=auto

# ── Native backend: which Windows processes go in which channel ──
# Channel 3 = "TV Broadcast" (browsers / game app / Discord, whatever
# produces the audio you want to mix into the broadcast)
AUDIO_CHANNEL_3_NAME=TV
AUDIO_CHANNEL_3_APPS=obs64,chrome,firefox,msedge,edge,opera,zen,vivaldi,brave,arc,helium,thorium

# Channel 4 = "Spotify" (halftime music)
AUDIO_CHANNEL_4_NAME=Spotify
AUDIO_CHANNEL_4_APPS=spotify

# ── Tunables ──────────────────────────────────────────────────────
AUDIO_FADE_DURATION_MS=900
AUDIO_DEBUG=false

# ── OBS preview (on-demand single-frame peek) ─────────────────────
#   Tap "peek" in the controller to capture ONE frame of this scene.
#   Used to check whether the live feed has resumed while the beamer
#   shows break images. No continuous streaming.
#   PREVIEW_SOURCE must match an OBS source/scene name exactly.
PREVIEW_SOURCE=Live Übertragung
PREVIEW_WIDTH=480
PREVIEW_QUALITY=70
