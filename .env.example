# ════════════════════════════════════════════════════════════════
# Euro Studio Configuration
# ════════════════════════════════════════════════════════════════

# ── OBS WebSocket ──────────────────────────────────────────────
OBS_WEBSOCKET_URL=ws://localhost:4455
OBS_WEBSOCKET_PASSWORD=your_password_here

# ── Audio Backend ──────────────────────────────────────────────
# auto            → Voicemeeter if available, else windows-simple (default)
# voicemeeter     → Voicemeeter only (fails if not installed)
# windows-simple  → Per-app volume via Windows audio sessions
# none            → No audio control (OBS scenes only)
AUDIO_BACKEND=auto

# ── Audio Channel Mapping (windows-simple mode) ────────────────
# Map logical channel IDs to process names (comma-separated).
# Only used when AUDIO_BACKEND is auto (fallback) or windows-simple.
AUDIO_CHANNEL_3_NAME=TV
AUDIO_CHANNEL_3_APPS=obs64,chrome

AUDIO_CHANNEL_4_NAME=Spotify
AUDIO_CHANNEL_4_APPS=spotify

# ── Voicemeeter-specific ───────────────────────────────────────
# Strip index used by the periodic VM health probe (default: 3)
VM_HEALTH_PROBE_STRIP=3

# ── Fade Settings ──────────────────────────────────────────────
# Duration in ms for Game/Break audio transitions (default: 900)
AUDIO_FADE_DURATION_MS=900

# ── Diagnostics ────────────────────────────────────────────────
# Set to 1 to enable verbose audio backend logging
AUDIO_DEBUG=0
